{
  "name": "tonylaw-monorepo",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "frontend/*",
    "backend/*",
    "packages/*"
  ],
  "scripts": {
    "dev:db": "docker compose up -d postgres",
    "dev:web": "bun --cwd frontend/option-web run dev",
    "dev:auth": "bun --cwd frontend/auth-web run dev",
    "dev:api": "bun --cwd backend/api run dev",
    "build:web": "bun --cwd frontend/option-web run build",
    "build:auth": "bun --cwd frontend/auth-web run build",
    "build:api": "bun --cwd backend/api run typecheck",
    "build": "bun run build:web && bun run build:auth && bun run build:api",
    "typecheck": "bun run --filter '*' typecheck"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.1.4"
  }
}
